# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_SECRET=client_secret

# Discord Application/Client ID
CLIENT_ID=your_client_id_here

# Discord Server (Guild) ID for testing
GUILD_ID=your_guild_id_here

# Google Sheets IDs
VOLUNTEERS_SHEET_ID=your_private_volunteer_sheet_id # Private sheet with "Limited Data" tab
LEADERSHIP_SHEET_ID=your_leadership_sheet_id 
EVENTS_SHEET_ID=your_public_events_sheet_id # Public sheet with "Signup Sheet" and "Tracker" tabs
VERIFICATION_SHEET_ID=your_verification_log_sheet_id # Sheet for logging verification submissions

# URLs
CALENDAR_URL=https://calendar.google.com/calendar/your_calendar_id
CALENDAR_ICAL_URL=
HOURS_FORM_URL=https://forms.google.com/your_hours_request_form

# Role IDs for Verification System
# These roles can run /verify and trigger welcome pings when assigned via onboarding

NT_MEMBER_ROLE_ID=000000000000000000
NT_UNVERIFIED_ROLE_ID=000000000000000000
COMBINED_UNVERIFIED_ROLE_ID=000000000000000000
EC_ROLE_ID=000000000000000000
BD_ROLE_ID=000000000000000000
VERIFICATION_TEAM_ROLE_ID=000000000000000000

# Channel IDs
STAFF_CHAT_CHANNEL_ID=your_verification_submissions_channel_id
VERIFICATION_CHANNEL_ID=your_welcome_ping_channel_id
INFO_SESSION_CHANNEL_ID=events_channel_id
NT_CHAT_ID=ntchat_id

# Reimbursement request notifications (posted via POST /reimbursement/submit on the onboarding HTTP server)
REIMBURSEMENT_THREAD_ID=your_reimbursement_thread_id

# Event Settings
INFO_SESSION_BANNER_URL=./ntbanner.png

# Periodic Checks
CHECK_LEFT_USERS_ENABLED=false

# Hour approval DMs (Hour Verification tab on EVENTS_SHEET_ID)
HOUR_APPROVAL_ENABLED=false
HOUR_APPROVAL_POLL_MINUTES=5
HOUR_APPROVAL_LOOKBACK_DAYS=30
HOUR_APPROVAL_SESSION_HOURS=168
# Optional Hour Verification layout (defaults shown)
HOUR_VERIFICATION_SHEET_RANGE=A1:ZZ
HOUR_VERIFICATION_HEADER_ROWS=2
HOUR_VERIFICATION_CONFIRMER_FIELD_COLUMN=5
HOUR_VERIFICATION_DATE_COLUMN=4

# Health Check
# Interval (in ms) between Healthchecks.io pings. 0 or unset disables pings. Example: 120000 = 2 minutes.
HEALTH_CHECK_INTERVAL_MS=0
